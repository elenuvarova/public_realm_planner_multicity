PORT=3001
NODE_ENV=development

# Leave DATABASE_URL blank locally — the backend serves its static datasets and
# /api/health reports db: none (no database needed for local dev).
# In production (Render) set DATABASE_URL to an EXTERNAL Postgres connection
# string, e.g. Neon:
#   postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL=
